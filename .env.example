# URL pública del sitio (sin slash final). Usala para metadata, sitemap y OG tags.
NEXT_PUBLIC_SITE_URL=https://www.mateoguillen.dev

# Email donde llegan los mensajes del formulario de contacto.
NEXT_PUBLIC_CONTACT_EMAIL=hola@mateoguillen.dev

# API key de Resend (https://resend.com) para enviar el formulario de contacto por email.
RESEND_API_KEY=

# Email "from" verificado en Resend. Mientras no verifiques un dominio propio,
# podés usar "onboarding@resend.dev" (modo de pruebas, solo te llega a vos).
CONTACT_FROM_EMAIL=Sitio web <onboarding@resend.dev>

# ID de Google Analytics 4 (formato G-XXXXXXXXXX). Dejalo vacío para desactivar GA.
NEXT_PUBLIC_GA_ID=
